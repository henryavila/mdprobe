{
  "name": "@henryavila/mdprobe",
  "version": "0.4.3",
  "description": "Markdown viewer + reviewer for terminal/WSL with live reload, persistent annotations, and AI agent integration",
  "type": "module",
  "bin": {
    "mdprobe": "./bin/cli.js"
  },
  "main": "./src/handler.js",
  "exports": {
    ".": "./src/handler.js",
    "./annotations": "./src/annotations.js",
    "./schema.json": "./schema.json"
  },
  "files": [
    "bin/",
    "src/",
    "dist/",
    "schema.json",
    "scripts/",
    "skills/",
    "templates/"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "build:ui": "vite build",
    "dev:ui": "vite dev",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^4.0.0",
    "diff-match-patch": "^1.0.5",
    "highlight.js": "^11.10.0",
    "js-yaml": "^4.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "unified": "^11.0.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@preact/preset-vite": "^2.9.0",
    "@preact/signals": "^2.0.0",
    "@testing-library/preact": "^3.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "ajv": "^8.17.0",
    "happy-dom": "^15.0.0",
    "htm": "^3.1.0",
    "preact": "^10.24.0",
    "supertest": "^7.0.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.0.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "markdown",
    "viewer",
    "reviewer",
    "annotations",
    "live-reload",
    "cli"
  ],
  "author": "Henry Avila",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/henryavila/mdprobe"
  }
}
